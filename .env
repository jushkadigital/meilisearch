# ==========================================
# Configuración de Meilisearch
# ==========================================

# ¡IMPORTANTE! Cambia esto por una cadena segura y aleatoria de al menos 16 caracteres
MEILI_MASTER_KEY=tu_clave_maestra_segura_para_produccion_2026

# Mantiene Meilisearch en modo producción (desactiva la interfaz web pública)
MEILI_ENV=production

# Privacidad y límites de recursos
MEILI_NO_ANALYTICS=true
MEILI_MAX_INDEXING_MEMORY=100Mb
MEILI_HTTP_PAYLOAD_SIZE_LIMIT=100Mb

# ==========================================
# Configuración del Worker (Bun)
# ==========================================

# URL de conexión a tu servidor de RabbitMQ
RABBITMQ_URL=amqp://admin:admin123@rabbitmq:5672

# URL interna de Meilisearch (Docker resuelve el nombre 'meilisearch' automáticamente)
MEILI_HOST=http://meilisearch:7700
